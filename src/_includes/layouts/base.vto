<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ title }}</title>
  <meta name="description" content="{{ description }}">
  <link rel="canonical" href="{{ site.url }}{{ url }}">
  <link rel="alternate" type="application/rss+xml" title="{{ site.author }} — Blog" href="/feed.rss">

  <!-- SEO Meta Tags -->
  <meta property="og:title" content="{{ title }}">
  <meta property="og:description" content="{{ description }}">
  {{ if type === "post" }}
  {{ set ogImage = cover || null }}
  <meta property="og:type" content="article">
  <meta property="og:url" content="{{ site.url }}{{ url }}">
  <meta property="article:published_time" content="{{ date |> date('DATE') }}">
  {{ if ogImage }}
  <meta property="og:image" content="{{ ogImage }}">
  <meta property="og:image:width" content="1200">
  <meta property="og:image:height" content="630">
  {{ /if }}
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="{{ title }}">
  <meta name="twitter:description" content="{{ description }}">
  {{ if ogImage }}
  <meta name="twitter:image" content="{{ ogImage }}">
  {{ /if }}
  {{ else }}
  <meta property="og:type" content="website">
  <meta property="og:url" content="{{ site.url }}{{ url }}">
  <meta property="og:image" content="{{ site.url }}/og-image.png">
  <meta property="og:image:width" content="1200">
  <meta property="og:image:height" content="630">
  <meta property="og:site_name" content="{{ site.author }}">
  <meta property="og:locale" content="en_US">
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="{{ title }}">
  <meta name="twitter:description" content="{{ description }}">
  <meta name="twitter:image" content="{{ site.url }}/og-image.png">
  {{ /if }}
  <meta name="author" content="{{ site.author }}">

  <!-- JSON-LD Structured Data -->
  {{ if type === "post" }}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "BlogPosting",
    "headline": "{{ title }}",
    "description": "{{ description }}",
    "url": "{{ site.url }}{{ url }}",
    "datePublished": "{{ date |> date('DATE') }}",
    "dateModified": "{{ date |> date('DATE') }}",
    {{ if cover }}
    "image": "{{ cover }}",
    {{ /if }}
    "author": {
      "@type": "Person",
      "name": "{{ site.author }}",
      "url": "{{ site.url }}"
    },
    "publisher": {
      "@type": "Person",
      "name": "{{ site.author }}",
      "url": "{{ site.url }}"
    },
    "mainEntityOfPage": {
      "@type": "WebPage",
      "@id": "{{ site.url }}{{ url }}"
    }
    {{ if tags }},
    "keywords": "{{ tags.join(', ') }}"
    {{ /if }}
  }
  </script>
  {{ else }}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "{{ site.author }}",
    "url": "{{ site.url }}",
    "description": "{{ description }}",
    "author": {
      "@type": "Person",
      "name": "{{ site.author }}",
      "url": "{{ site.url }}",
      "jobTitle": "{{ site.tagline }}"
    }
  }
  </script>
  {{ /if }}

  <!-- Styles (inlined for performance) -->
  <link rel="stylesheet" href="/styles/main.css" inline>

  {{ include "partials/head-theme-flash.vto" }}
  {{ include "partials/head-prefetch.vto" }}
</head>
<body>
  <!-- Skip to main content link for accessibility -->
  <a href="#main-content" class="skip-link">Skip to main content</a>

  {{ if type === "post" }}
  <!-- Reading Progress Bar -->
  <div class="reading-progress" id="readingProgress"></div>
  {{ /if }}

  <!-- Theme Toggle -->
  <button class="floating-btn theme-toggle" id="themeToggle" aria-label="Toggle theme">
    <svg class="sun-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"/>
    </svg>
    <svg class="moon-icon" style="display: none;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"/>
    </svg>
  </button>

  <!-- Back to Top Button -->
  <button class="floating-btn back-to-top" id="backToTop" aria-label="Back to top">
    <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 10l7-7m0 0l7 7m-7-7v18"/>
    </svg>
  </button>

  {{ if type === "post" }}
  <!-- Image Lightbox -->
  <div class="lightbox" id="lightbox" aria-hidden="true">
    <button class="lightbox-close" id="lightboxClose" aria-label="Close lightbox">&times;</button>
    <button class="lightbox-nav lightbox-prev" id="lightboxPrev" aria-label="Previous image">
      <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
      </svg>
    </button>
    <button class="lightbox-nav lightbox-next" id="lightboxNext" aria-label="Next image">
      <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
      </svg>
    </button>
    <div class="lightbox-content">
      <img class="lightbox-image" id="lightboxImage" src="" alt="">
      <p class="lightbox-caption" id="lightboxCaption"></p>
    </div>
  </div>
  {{ /if }}

  <!-- Header -->
  <header>
    <div class="container">
      <h1>{{ site.author }}</h1>
      <p style="color: var(--color-text-secondary); margin-bottom: 2rem;">{{ site.tagline }}</p>
    </div>
  </header>

  <!-- Main Content -->
  <main id="main-content" tabindex="-1">
    {{ content }}
  </main>

  <!-- Footer -->
  <footer>
    <div class="container">
      <p>© <span id="year"></span> {{ site.author }}</p>
    </div>
  </footer>

  {{ include "partials/scripts-common.vto" }}
  {{ include "partials/scripts-sw.vto" }}
</body>
</html>
