#!/bin/sh

set -e

staged_files=$(git diff --cached --name-only)

if [ -z "$staged_files" ]; then
  exit 0
fi

for file in $staged_files; do
  case "$file" in
    resume.json|main.typ|_cache/*|_cache/*/*|_cache/*/*/*)
      printf "Blocked: %s must not be committed.\n" "$file" >&2
      printf "Remove it from the index: git restore --staged %s\n" "$file" >&2
      exit 1
      ;;
  esac
done

format_files=""
for file in $staged_files; do
  case "$file" in
    src/*|_config.ts)
      format_files="$format_files $file"
      ;;
  esac
done

if [ -n "$format_files" ]; then
  deno fmt $format_files
  deno lint $format_files
  git add $format_files
fi
